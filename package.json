{
  "name": "nubem-drive",
  "private": true,
  "version": "0.0.82",
  "description": "Private folder cloud desktop app.",
  "author": "Nando <nando@nubem.org>",
  "homepage": "https://drive.nubem.org",
  "type": "module",
  "main": "electron/main.cjs",
  "scripts": {
    "dev": "concurrently -k \"vite --host 127.0.0.1\" \"wait-on http://127.0.0.1:5173 && node scripts/start-electron.cjs\"",
    "dev:server": "concurrently -k \"vite --host 127.0.0.1\" \"wait-on http://127.0.0.1:5173 && NUBEM_APP_FLAVOR=server node scripts/start-electron.cjs\"",
    "web:dev": "vite --host 127.0.0.1",
    "build": "tsc -b && vite build",
    "dist:client:linux": "npm run build && electron-builder --config electron-builder.client.cjs --linux deb --x64",
    "dist:server:linux": "npm run build && electron-builder --config electron-builder.server.cjs --linux deb --x64",
    "dist:linux": "npm run dist:client:linux && npm run dist:server:linux",
    "dist:client:win": "npm run build && electron-builder --config electron-builder.client.cjs --win nsis --x64",
    "dist:win": "npm run dist:client:win",
    "dist:all": "npm run dist:linux",
    "electron": "node scripts/start-electron.cjs",
    "electron:server": "NUBEM_APP_FLAVOR=server node scripts/start-electron.cjs",
    "lint": "eslint .",
    "preview": "vite preview",
    "storage": "NUBEM_DRIVE_STATE=$HOME/.config/nubem-server/state.json node server/storage-node.cjs"
  },
  "dependencies": {
    "lucide-react": "^1.18.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1"
  },
  "devDependencies": {
    "@eslint/js": "^9.13.0",
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.1",
    "@vitejs/plugin-react": "^4.3.3",
    "concurrently": "^8.2.2",
    "electron": "^28.3.3",
    "electron-builder": "^24.13.3",
    "eslint": "^9.13.0",
    "eslint-plugin-react-hooks": "^5.0.0",
    "eslint-plugin-react-refresh": "^0.4.14",
    "globals": "^15.11.0",
    "rcedit": "^5.0.2",
    "typescript": "~5.6.2",
    "typescript-eslint": "^8.11.0",
    "vite": "^5.4.10",
    "wait-on": "^7.2.0"
  }
}

{
  "name": "nubem-drive",
  "private": true,
  "version": "0.0.26",
  "description": "Private folder cloud desktop app.",
  "author": "Nando <nando@nubem.org>",
  "homepage": "https://drive.nubem.org",
  "type": "module",
  "main": "electron/main.cjs",
  "scripts": {
    "dev": "concurrently -k \"vite --host 127.0.0.1\" \"wait-on http://127.0.0.1:5173 && node scripts/start-electron.cjs\"",
    "web:dev": "vite --host 127.0.0.1",
    "build": "tsc -b && vite build",
    "dist:linux": "npm run build && electron-builder --linux deb --x64",
    "dist:win": "npm run build && electron-builder --win nsis --x64",
    "dist:all": "npm run build && electron-builder --linux deb --win nsis --x64",
    "electron": "node scripts/start-electron.cjs",
    "lint": "eslint .",
    "preview": "vite preview",
    "storage": "node server/storage-node.cjs"
  },
  "dependencies": {
    "lucide-react": "^1.18.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1"
  },
  "devDependencies": {
    "@eslint/js": "^9.13.0",
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.1",
    "@vitejs/plugin-react": "^4.3.3",
    "concurrently": "^8.2.2",
    "electron": "^28.3.3",
    "electron-builder": "^24.13.3",
    "eslint": "^9.13.0",
    "eslint-plugin-react-hooks": "^5.0.0",
    "eslint-plugin-react-refresh": "^0.4.14",
    "globals": "^15.11.0",
    "typescript": "~5.6.2",
    "typescript-eslint": "^8.11.0",
    "vite": "^5.4.10",
    "wait-on": "^7.2.0"
  },
  "build": {
    "appId": "org.nubem.drive",
    "productName": "Nubem Drive",
    "directories": {
      "output": "release"
    },
    "files": [
      "dist/**/*",
      "electron/**/*",
      "server/**/*",
      "package.json"
    ],
    "linux": {
      "target": [
        "deb"
      ],
      "category": "Utility",
      "maintainer": "Nando <nando@nubem.org>",
      "executableName": "nubem-drive",
      "artifactName": "Nubem-Drive-${version}-${arch}.${ext}"
    },
    "deb": {
      "afterInstall": "build/linux/after-install.sh",
      "afterRemove": "build/linux/after-remove.sh"
    },
    "win": {
      "target": [
        "nsis"
      ],
      "signAndEditExecutable": false,
      "executableName": "Nubem Drive",
      "artifactName": "Nubem-Drive-Setup-${version}-${arch}.${ext}"
    },
    "nsis": {
      "oneClick": false,
      "perMachine": false,
      "allowToChangeInstallationDirectory": true,
      "include": "build/nsis/context-menu.nsh"
    }
  }
}
